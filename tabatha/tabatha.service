[Unit]
Description=tabatha Discord Bot
After=network.target

[Service]
Type=simple
User=snerloc
WorkingDirectory=/home/snerloc/discord-bots/tabatha
Environment=PERSONA_FILE=/home/snerloc/discord-bots/tabatha/personas/tabatha.txt
Environment=LLM_MODEL=dolphin-2.8-mistral-7b-v02
Environment=ALLOWED_CHANNELS=1503348313397923871,1504438057103790120
Environment=ALLOW_BOT_MESSAGES=true
Environment=BOT_NAME=tabatha
ExecStart=/usr/bin/node /home/snerloc/discord-bots/shared/bot.js
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
