[Unit]
Description=Annalise Discord Bot
After=network.target

[Service]
Type=simple
User=snerloc
WorkingDirectory=/home/snerloc/discord-bots/bot6
ExecStart=/usr/bin/node /home/snerloc/discord-bots/shared/bot-runtime.js --persona bot6
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
